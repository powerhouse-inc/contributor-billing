{
  "name": "@powerhousedao/contributor-billing",
  "description": "Document models that help contributors of open organisations get paid anonymously for their work on a monthly basis.",
  "version": "1.0.0-dev.38",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/powerhouse-inc/contributor-billing.git"
  },
  "type": "module",
  "files": [
    "/dist",
    "/browser",
    "style.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/index.js",
      "node": "./dist/node/index.mjs"
    },
    "./document-models": {
      "types": "./dist/document-models/index.d.ts",
      "browser": "./dist/browser/document-models/index.js",
      "node": "./dist/node/document-models/index.mjs"
    },
    "./document-models/*": {
      "types": "./dist/document-models/*/index.d.ts",
      "browser": "./dist/browser/document-models/*/index.js",
      "node": "./dist/node/document-models/*/index.mjs"
    },
    "./editors": {
      "types": "./dist/editors/index.d.ts",
      "browser": "./dist/browser/editors/index.js",
      "node": "./dist/node/editors/index.mjs"
    },
    "./editors/*": {
      "types": "./dist/editors/*/index.d.ts",
      "browser": "./dist/browser/editors/*/index.js",
      "node": "./dist/node/editors/*/index.mjs"
    },
    "./subgraphs": {
      "types": "./dist/subgraphs/index.d.ts",
      "browser": "./dist/browser/subgraphs/index.js",
      "node": "./dist/node/subgraphs/index.mjs"
    },
    "./processors": {
      "types": "./dist/processors/index.d.ts",
      "browser": "./dist/browser/processors/index.js",
      "node": "./dist/node/processors/index.mjs"
    },
    "./manifest": "./dist/powerhouse.manifest.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config eslint.config.js --cache --cache-strategy content",
    "lint:fix": "npm run lint -- --fix",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "check-circular-imports": "npx dpdm -T ./index.ts",
    "generate": "ph-cli generate",
    "connect": "ph-cli connect",
    "build": "bun run build.ts",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "vetra": "ph-cli vetra",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh"
  },
  "dependencies": {
    "@powerhousedao/analytics-engine-core": "6.0.0-dev.202",
    "@powerhousedao/builder-profile": "1.1.0-dev.30",
    "@powerhousedao/connect": "6.0.0-dev.202",
    "@powerhousedao/design-system": "6.0.0-dev.202",
    "@powerhousedao/document-engineering": "1.40.2",
    "@powerhousedao/reactor-api": "6.0.0-dev.202",
    "@powerhousedao/reactor-browser": "6.0.0-dev.202",
    "@powerhousedao/service-offering": "1.0.0-dev.40",
    "@powerhousedao/shared": "6.0.0-dev.202",
    "@react-pdf/renderer": "^4.3.1",
    "@safe-global/api-kit": "^4.0.0",
    "@safe-global/protocol-kit": "^6.0.3",
    "@safe-global/sdk-starter-kit": "^2.0.2",
    "@safe-global/types-kit": "^2.0.1",
    "@types/cors": "^2.8.17",
    "cors": "^2.8.5",
    "document-model": "6.0.0-dev.202",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.0",
    "google-auth-library": "^9.15.1",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "world-countries": "^5.1.0",
    "zod": "^4.3.5"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.15",
    "@electric-sql/pglite-tools": "0.2.20",
    "@eslint/js": "^9.38.0",
    "@powerhousedao/ph-cli": "6.0.0-dev.202",
    "@powerhousedao/reactor": "6.0.0-dev.202",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "8.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.1"
  },
  "bugs": {
    "url": "https://github.com/powerhouse-inc/contributor-billing/issues"
  },
